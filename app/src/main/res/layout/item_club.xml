<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/separator"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Club header row: icon + name/tags + joined chip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Club Icon Circle -->
            <FrameLayout
                android:id="@+id/club_icon_bg"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_club_icon_circle">
                <ImageView
                    android:id="@+id/club_logo"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_compass"
                    app:tint="@color/primary" />
            </FrameLayout>

            <!-- Club name + category chip -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/club_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_club_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_points"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="Technology"
                        android:textColor="@color/badge_points_text"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/club_members"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Joined status chip (top right) -->
            <TextView
                android:id="@+id/tv_joined_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_beginner"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Joined"
                android:textColor="@color/badge_beginner_text"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/club_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:background="@color/separator" />

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Join / Joined Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_join"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Join Club"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="@color/secondary"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_clubs"
                app:iconSize="16dp"
                app:iconPadding="4dp"
                app:iconTint="@color/white"/>

            <!-- View Club Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_club"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="View Club"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                android:textSize="13sp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp" />

            <!-- Delete button (admin only) -->
            <ImageButton
                android:id="@+id/btn_delete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                android:visibility="gone"
                app:tint="@color/error_red" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>