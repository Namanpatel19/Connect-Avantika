<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Icon -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#1A00BFA5"
            app:cardElevation="0dp">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_upload"
                app:tint="@color/primary"
                android:rotation="180"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvMaterialTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Material Title"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvMaterialSubject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subject"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvUploadedBy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Uploaded by: -"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:textStyle="italic"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBatch"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:textSize="10sp"
                    app:chipMinHeight="24dp"
                    app:chipBackgroundColor="#1A00BFA5"
                    app:chipStrokeWidth="0dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDept"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:textSize="10sp"
                    android:layout_marginStart="4dp"
                    app:chipMinHeight="24dp"
                    app:chipBackgroundColor="#1A009688"
                    app:chipStrokeWidth="0dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnView"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_check"
                app:tint="@color/primary"
                android:contentDescription="View/Download" />

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_shield"
                app:tint="#EF5350"
                android:contentDescription="Delete" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
