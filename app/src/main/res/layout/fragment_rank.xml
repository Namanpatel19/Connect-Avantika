<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_deep">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_teal_header"
        android:padding="20dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Leaderboard"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Compete with fellow students"
            android:textColor="#CCffffff"
            android:textSize="14sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Podium / Top 3 -->
                <LinearLayout
                    android:id="@+id/layoutPodium"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:paddingBottom="16dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <!-- Rank 2 -->
                    <LinearLayout
                        android:id="@+id/layoutRank2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/ivRank2"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/ic_person"
                            android:background="@drawable/bg_circle_white"
                            android:padding="4dp"
                            android:scaleType="centerCrop" />
                        <TextView
                            android:id="@+id/tvNameRank2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:maxLines="1"
                            android:ellipsize="end"/>
                        <TextView
                            android:id="@+id/tvPtsRank2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 pts"
                            android:textSize="10sp"
                            android:textColor="@color/primary"/>
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/primary_light"
                            android:alpha="0.5"/>
                    </LinearLayout>

                    <!-- Rank 1 -->
                    <LinearLayout
                        android:id="@+id/layoutRank1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/ivRank1"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_person"
                            android:background="@drawable/bg_circle_white"
                            android:padding="4dp"
                            android:scaleType="centerCrop" />
                        <TextView
                            android:id="@+id/tvNameRank1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:maxLines="1"
                            android:ellipsize="end"/>
                        <TextView
                            android:id="@+id/tvPtsRank1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 pts"
                            android:textSize="12sp"
                            android:textColor="@color/primary"/>
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/primary"/>
                    </LinearLayout>

                    <!-- Rank 3 -->
                    <LinearLayout
                        android:id="@+id/layoutRank3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/ivRank3"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/ic_person"
                            android:background="@drawable/bg_circle_white"
                            android:padding="4dp"
                            android:scaleType="centerCrop" />
                        <TextView
                            android:id="@+id/tvNameRank3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:maxLines="1"
                            android:ellipsize="end"/>
                        <TextView
                            android:id="@+id/tvPtsRank3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 pts"
                            android:textSize="10sp"
                            android:textColor="@color/primary"/>
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="30dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/accent"
                            android:alpha="0.5"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student Rankings"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRankings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_student" />

            </LinearLayout>
        </ScrollView>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No rankings found"
            android:textColor="@color/text_primary"
            android:visibility="gone" />

    </FrameLayout>
</LinearLayout>
