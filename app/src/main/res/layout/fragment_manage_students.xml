<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_deep">

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_teal_header" android:padding="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Manage Students" android:textColor="@color/white"
            android:textSize="20sp" android:textStyle="bold"/>
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_margin="16dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Search students..." android:inputType="text"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView android:id="@+id/tvCount"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="All Students" android:textColor="@color/text_secondary"
        android:textSize="13sp" android:layout_marginHorizontal="16dp" android:layout_marginBottom="8dp"/>

    <ProgressBar android:id="@+id/progressBar"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal" android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvStudents"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="16dp" android:clipToPadding="false"/>
</LinearLayout>
