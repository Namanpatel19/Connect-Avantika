<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_student"
    app:startDestination="@id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.myapplication.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_events"
        android:name="com.example.myapplication.EventsFragment"
        android:label="Events"
        tools:layout="@layout/fragment_events" />

    <fragment
        android:id="@+id/navigation_clubs"
        android:name="com.example.myapplication.ClubsFragment"
        android:label="Clubs"
        tools:layout="@layout/fragment_clubs">
        <action
            android:id="@+id/action_clubs_to_details"
            app:destination="@id/navigation_club_details"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/navigation_club_details"
        android:name="com.example.myapplication.ClubDetailsFragment"
        android:label="Club Info"
        tools:layout="@layout/fragment_club_details">
        <argument
            android:name="club_id"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/navigation_notices"
        android:name="com.example.myapplication.NoticesFragment"
        android:label="Notices"
        tools:layout="@layout/fragment_notices" />

    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.example.myapplication.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />
</navigation>
